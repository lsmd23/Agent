{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-attention.local/schemas/benchmark_task.v0.1.schema.json",
  "title": "Agent-Attention Benchmark Task Schema",
  "description": "Schema for Phase 0-1 benchmark tasks. Each task has an explicit success label and success oracle.",
  "x_metadata": {
    "scope": "Reusable task schema for code, search, and mini-research Agent-Attention benchmark tasks.",
    "claims": [
      {
        "evidence_type": "文献",
        "claim": "Agent and routing benchmarks require task-level oracles and controlled baseline interfaces."
      },
      {
        "evidence_type": "原型",
        "claim": "Subtask 06 runtime tasks can be represented as synthetic_runtime tasks with route and budget expectations."
      },
      {
        "evidence_type": "实验",
        "claim": "Seed tasks can verify metric computability before large-scale experiments."
      },
      {
        "evidence_type": "猜想",
        "claim": "Explicit negative-transfer probes are needed because harmful memory reuse is otherwise rare in tiny suites."
      }
    ],
    "design": {
      "minimal_version": "Task prompt, family, budget, success oracle, expected route, and baseline applicability.",
      "enhanced_version": "Executable environments, frozen evidence snapshots, oracle route matrices, memory injection profiles, and train/eval split provenance.",
      "counterexamples": [
        "A prompt without a success oracle cannot distinguish correct cheap answers from wrong cheap answers.",
        "A task without budget ceilings cannot support fair MoA or router comparisons.",
        "A memory-transfer task without injected harmful or stale memories may never expose negative transfer."
      ]
    },
    "interfaces": {
      "aligned_with": [
        "docs/deliverables/02/formal_spec.md benchmark fields",
        "docs/deliverables/06/runtime_report.md legacy task strings"
      ],
      "known_deviations": [
        "Subtask 06 CLI accepts a raw task string, not this full task object.",
        "Real executable pytest and citation oracles are declared here but not implemented by the toy runtime."
      ]
    },
    "experiments": [
      "Validate seed tasks against this schema.",
      "Join task oracle fields with scored trajectories to compute task-family metrics."
    ],
    "risks": [
      "Rubric oracles need reviewer calibration.",
      "Expected routes can bias router evaluation if used during execution rather than scoring."
    ],
    "open_questions": [
      "Should Phase 1 require every task to have an oracle route, or only synthetic route probes?",
      "Should human-rubric tasks be excluded from automated CI scoring?"
    ]
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "benchmark_id",
    "task_family",
    "split",
    "prompt",
    "environment",
    "budget",
    "success_oracle",
    "expected_route",
    "baseline_applicability",
    "negative_transfer_probe"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_.:-]+$"
    },
    "benchmark_id": {
      "type": "string"
    },
    "task_family": {
      "enum": [
        "code_agent_task",
        "search_agent_task",
        "mini_research_task"
      ]
    },
    "split": {
      "enum": [
        "seed",
        "train",
        "validation",
        "test",
        "held_out"
      ]
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_type",
        "supports_executable_feedback",
        "supports_oracle_route",
        "required_tooling",
        "frozen_inputs"
      ],
      "properties": {
        "environment_type": {
          "enum": [
            "synthetic_runtime",
            "executable_repo",
            "static_dataset",
            "frozen_search_snapshot",
            "human_rubric"
          ]
        },
        "supports_executable_feedback": {
          "type": "boolean"
        },
        "supports_oracle_route": {
          "type": "boolean"
        },
        "required_tooling": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frozen_inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "input_id",
              "kind",
              "description"
            ],
            "properties": {
              "input_id": {
                "type": "string"
              },
              "kind": {
                "enum": [
                  "repo_fixture",
                  "source_snapshot",
                  "memory_corpus",
                  "task_text",
                  "none"
                ]
              },
              "description": {
                "type": "string"
              },
              "path": {
                "type": [
                  "string",
                  "null"
                ]
              }
            }
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_steps",
        "max_module_calls",
        "max_tool_calls",
        "max_verifier_calls",
        "max_tokens",
        "max_latency_ms",
        "max_activation_cost"
      ],
      "properties": {
        "max_steps": {
          "type": "integer",
          "minimum": 1
        },
        "max_module_calls": {
          "type": "integer",
          "minimum": 0
        },
        "max_tool_calls": {
          "type": "integer",
          "minimum": 0
        },
        "max_verifier_calls": {
          "type": "integer",
          "minimum": 0
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "max_latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "max_activation_cost": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "success_oracle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "oracle_type",
        "success_label",
        "criteria"
      ],
      "properties": {
        "oracle_type": {
          "enum": [
            "exact_match",
            "regex",
            "pytest",
            "citation_rubric",
            "human_rubric",
            "synthetic_runtime",
            "schema_check"
          ]
        },
        "success_label": {
          "enum": [
            "pass",
            "fail",
            "partial",
            "unknown"
          ]
        },
        "expected_answer": {
          "type": [
            "string",
            "null"
          ]
        },
        "expected_tests": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "criterion_id",
              "description",
              "weight",
              "required"
            ],
            "properties": {
              "criterion_id": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "weight": {
                "type": "number",
                "minimum": 0
              },
              "required": {
                "type": "boolean"
              }
            }
          }
        },
        "citation_requirements": {
          "type": "object",
          "additionalProperties": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "expected_route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "oracle_available",
        "required_modules",
        "allowed_modules",
        "discouraged_modules"
      ],
      "properties": {
        "oracle_available": {
          "type": "boolean"
        },
        "required_modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allowed_modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "discouraged_modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "oracle_best_module_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "route_rationale": {
          "type": "string"
        }
      }
    },
    "memory_setup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_memory_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "injected_memory_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "quarantined_memory_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "negative_transfer_probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "probe_type",
        "harmful_memory_ids",
        "expected_detection"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "probe_type": {
          "enum": [
            "none",
            "irrelevant_memory",
            "stale_memory",
            "contradictory_memory",
            "wrong_route_memory"
          ]
        },
        "harmful_memory_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_detection": {
          "type": "string"
        }
      }
    },
    "baseline_applicability": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "required": [
        "single_react_agent",
        "fixed_workflow_agent",
        "retrieval_memory_agent",
        "fixed_moa_agent",
        "agent_attention_agent"
      ]
    },
    "scoring": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_metric": {
          "type": "string"
        },
        "secondary_metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
